{
  "name": "omakase",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Omakase — agent runtime, multi-agent orchestration core, and CLI/TUI for autonomous software work.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/omakase.git"
  },
  "homepage": "https://github.com/your-org/omakase#readme",
  "bugs": "https://github.com/your-org/omakase/issues",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:watch": "pnpm -r --parallel exec tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "pnpm -r typecheck && pnpm -r test",
    "clean": "pnpm -r exec rm -rf dist *.tsbuildinfo",
    "link:global": "mkdir -p \"$HOME/.local/bin\" && ln -sf \"$PWD/scripts/omakase.sh\" \"$HOME/.local/bin/omakase\" && echo \"linked: $HOME/.local/bin/omakase -> $PWD/scripts/omakase.sh\""
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
