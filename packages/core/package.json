{
  "name": "@omakase/core",
  "version": "0.1.0",
  "description": "Omakase orchestration core — router, plan graph, hooks, knowledge (wiki + codegraph), spec/TDD workflows, and a resumable Ralph-loop supervisor built on @omakase/daemon.",
  "type": "module",
  "license": "MIT",
  "keywords": ["agent", "ai", "orchestration", "multi-agent", "ralph-loop", "planner"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/omakase.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/your-org/omakase#readme",
  "bugs": "https://github.com/your-org/omakase/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@omakase/daemon": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
