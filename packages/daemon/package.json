{
  "name": "@omakase/daemon",
  "version": "0.1.0",
  "description": "Omakase agent runtime daemon — detect local agent CLIs, run them through a unified streaming protocol, and load skills. Dependency-free base layer for any Omakase agent.",
  "type": "module",
  "license": "MIT",
  "keywords": ["agent", "ai", "cli", "claude", "codex", "runtime", "mcp"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/omakase.git",
    "directory": "packages/daemon"
  },
  "homepage": "https://github.com/your-org/omakase#readme",
  "bugs": "https://github.com/your-org/omakase/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  }
}
