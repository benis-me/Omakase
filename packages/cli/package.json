{
  "name": "@omakase/cli",
  "version": "0.1.0",
  "description": "Omakase headless command-line entrypoint. Detect agents, run tasks, and drive the orchestrator — all on top of @omakase/core, persisting through @omakase/storage.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "agent",
    "ai",
    "cli",
    "omakase"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/omakase.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/your-org/omakase#readme",
  "bugs": "https://github.com/your-org/omakase/issues",
  "bin": {
    "omakase": "./bin/omakase.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "omakase": "node bin/omakase.mjs",
    "dev": "tsx src/dev.ts"
  },
  "dependencies": {
    "@omakase/core": "workspace:*",
    "@omakase/daemon": "workspace:*",
    "@omakase/storage": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
