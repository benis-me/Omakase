{
  "name": "@omakase/cli",
  "version": "0.1.0",
  "description": "Omakase command-line + TUI entrypoint. Detect agents, run tasks, and drive the orchestrator interactively — all on top of @omakase/core.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "agent",
    "ai",
    "cli",
    "tui",
    "ink",
    "omakase"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/omakase.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/your-org/omakase#readme",
  "bugs": "https://github.com/your-org/omakase/issues",
  "bin": {
    "omakase": "./bin/omakase.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "omakase": "node bin/omakase.mjs",
    "dev": "tsx src/dev.ts",
    "test:tui": "bun --conditions=development run tests-bun/smoke.tsx"
  },
  "dependencies": {
    "@omakase/core": "workspace:*",
    "@omakase/daemon": "workspace:*",
    "@opentui/core": "0.4.1",
    "@opentui/react": "0.4.1",
    "react": "^19"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  }
}
