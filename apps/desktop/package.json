{
  "name": "@omakase/desktop",
  "version": "0.1.0",
  "description": "Omakase Desktop — a cockpit for spec-driven, long-running, autonomous multi-agent work.",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "predev": "electron-builder install-app-deps",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "rebuild:electron": "electron-builder install-app-deps",
    "rebuild:node": "pnpm rebuild better-sqlite3"
  },
  "build": {
    "appId": "com.omakase.desktop",
    "productName": "Omakase",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/node-pty/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "title": "Omakase ${version}"
    }
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-markdown": "^6.3.4",
    "@dnd-kit/dom": "^0.5.0",
    "@dnd-kit/helpers": "^0.5.0",
    "@dnd-kit/react": "^0.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@omakase/core": "workspace:*",
    "@omakase/daemon": "workspace:*",
    "@omakase/storage": "workspace:*",
    "@uiw/react-codemirror": "^4.25.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "lucide-react": "^1.18.0",
    "marked": "^16.4.1",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "playwright-core": "^1.61.1",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.5",
    "vitest": "^3.2.4"
  }
}
